<Application x:Class="QuickLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QuickLauncher">
    <Application.Resources>
        <!-- ===== Color System ===== -->
        <SolidColorBrush x:Key="BgBase" Color="#0B0F19" />
        <SolidColorBrush x:Key="BgPanel" Color="#E00F172A" />
        <SolidColorBrush x:Key="BgCard" Color="#B81B2336" />
        <SolidColorBrush x:Key="BgCardHover" Color="#D9253048" />
        <SolidColorBrush x:Key="BgCardSelected" Color="#591D4ED8" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8" />
        <SolidColorBrush x:Key="TextMuted" Color="#64748B" />
        <SolidColorBrush x:Key="Accent" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentSubtle" Color="#2660A5FA" />
        <SolidColorBrush x:Key="BorderDefault" Color="#1E94A3B8" />
        <SolidColorBrush x:Key="BorderFocus" Color="#6660A5FA" />
        <SolidColorBrush x:Key="Destructive" Color="#EF4444" />
        <SolidColorBrush x:Key="Success" Color="#22C55E" />

        <!-- ===== Corner Radius ===== -->
        <CornerRadius x:Key="RadiusPanel">16</CornerRadius>
        <CornerRadius x:Key="RadiusCard">12</CornerRadius>
        <CornerRadius x:Key="RadiusSearch">12</CornerRadius>
        <CornerRadius x:Key="RadiusBadge">6</CornerRadius>

        <!-- ===== Search Icon Geometry ===== -->
        <StreamGeometry x:Key="SearchIconGeometry">M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zM9.5 14C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z</StreamGeometry>

        <!-- ===== Shadow Effects ===== -->
        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="32"
                          ShadowDepth="0"
                          Color="#020617"
                          Opacity="0.6" />
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="16"
                          ShadowDepth="0"
                          Color="#020617"
                          Opacity="0.3" />

        <!-- ===== Dark ScrollBar Style ===== -->
        <Style x:Key="DarkScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#3394A3B8"
                                CornerRadius="3"
                                Margin="1" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#5594A3B8" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#7794A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollBarThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="8" />
                    <Setter Property="MinHeight" Value="8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource DarkScrollBarThumb}" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
