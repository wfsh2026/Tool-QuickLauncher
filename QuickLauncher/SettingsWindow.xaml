<Window x:Class="QuickLauncher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置"
        Width="600"
        Height="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}" />
            <Setter Property="Background" Value="{StaticResource BgCard}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#1D4ED8" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark CheckBox -->
        <Style x:Key="DarkCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder"
                                    Width="18" Height="18"
                                    CornerRadius="4"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1"
                                    Margin="0,0,8,0">
                                <Path x:Name="CheckMark"
                                      Data="M3,7 L6,10 L11,4"
                                      Stroke="{StaticResource Accent}"
                                      StrokeThickness="2"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                <Setter TargetName="CheckBorder" Property="Background" Value="{StaticResource AccentSubtle}" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource TextSecondary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Margin="8"
            Background="{StaticResource BgPanel}"
            CornerRadius="{StaticResource RadiusPanel}"
            BorderBrush="{StaticResource BorderDefault}"
            BorderThickness="1"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Padding="20,14" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="设置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Width="28" Height="28"
                            Click="CloseButton_OnClick"
                            Cursor="Hand"
                            ToolTip="关闭">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CloseBd"
                                        Background="Transparent"
                                        CornerRadius="6"
                                        Width="28" Height="28">
                                    <Path Data="M6,6 L18,18 M18,6 L6,18"
                                          Stroke="{StaticResource TextMuted}"
                                          StrokeThickness="1.5"
                                          Width="14" Height="14"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBd" Property="Background" Value="{StaticResource BgCardHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="管理快捷键、搜索源和启动行为。"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" />
                    </StackPanel>

                    <!-- Hotkey -->
                    <Border Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="唤起快捷键" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" />
                            <WrapPanel Margin="0,12,0,0">
                                <CheckBox x:Name="CtrlCheckBox" Content="Ctrl" Margin="0,0,16,8" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                                <CheckBox x:Name="AltCheckBox" Content="Alt" Margin="0,0,16,8" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                                <CheckBox x:Name="ShiftCheckBox" Content="Shift" Margin="0,0,16,8" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                                <CheckBox x:Name="WinCheckBox" Content="Win" Margin="0,0,16,8" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                            </WrapPanel>
                            <ComboBox x:Name="KeyComboBox"
                                      Margin="0,8,0,0"
                                      Height="34"
                                      Background="{StaticResource BgCard}"
                                      Foreground="Black"
                                      BorderBrush="{StaticResource BorderDefault}"
                                      SelectionChanged="OnSettingChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                            <TextBlock Text="至少选择一个修饰键和一个主键。"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>

                    <!-- Startup -->
                    <Border Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="启动行为" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" />
                            <CheckBox x:Name="RunAtStartupCheckBox" Content="开机启动" Margin="0,12,0,0" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                            <CheckBox x:Name="HideAfterLaunchCheckBox" Content="启动应用后自动隐藏" Margin="0,8,0,0" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                        </StackPanel>
                    </Border>

                    <!-- Search Sources -->
                    <Border Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="搜索来源" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" />
                            <CheckBox x:Name="SearchStartMenuCheckBox" Content="开始菜单" Margin="0,12,0,0" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                            <CheckBox x:Name="SearchDesktopCheckBox" Content="桌面快捷方式" Margin="0,8,0,0" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                            <CheckBox x:Name="SearchUwpCheckBox" Content="UWP 应用" Margin="0,8,0,0" Style="{StaticResource DarkCheckBoxStyle}" Checked="OnSettingChanged" Unchecked="OnSettingChanged" />
                        </StackPanel>
                    </Border>

                    <!-- Custom Folders -->
                    <Border Grid.Row="4" Margin="0,10,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="自定义目录" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" />
                            <ListBox x:Name="CustomFoldersListBox"
                                     Height="110"
                                     Margin="0,10,0,0"
                                     Background="{StaticResource BgBase}"
                                     Foreground="{StaticResource TextSecondary}"
                                     BorderBrush="{StaticResource BorderDefault}"
                                     BorderThickness="1" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Margin="0,0,10,0" Click="AddFolderButton_OnClick" Style="{StaticResource SecondaryButtonStyle}">添加目录</Button>
                                <Button Click="RemoveFolderButton_OnClick" Style="{StaticResource SecondaryButtonStyle}">移除选中</Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Index Status -->
                    <Border Grid.Row="5" Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="索引状态" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" />
                                <TextBlock x:Name="IndexStatusTextBlock" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="13" />
                            </StackPanel>
                            <DockPanel Grid.Row="1" Margin="0,12,0,0">
                                <Button x:Name="RebuildIndexButton"
                                        Width="110"
                                        Click="RebuildIndexButton_OnClick"
                                        Style="{StaticResource SecondaryButtonStyle}">重建索引</Button>
                            </DockPanel>
                        </Grid>
                    </Border>

                    <!-- Hidden Entries (恢复已删除的索引) -->
                    <Border Grid.Row="6" Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="已删除的索引" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="从搜索中删除的应用会显示在这里，可重新加入。"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12" />
                            <ListBox x:Name="HiddenEntriesListBox"
                                     Height="140"
                                     Margin="0,10,0,0"
                                     Background="{StaticResource BgBase}"
                                     Foreground="{StaticResource TextSecondary}"
                                     BorderBrush="{StaticResource BorderDefault}"
                                     BorderThickness="1"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SourceText}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="11"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Padding="14,4"
                                                    Click="UnhideButton_OnClick"
                                                    Style="{StaticResource SecondaryButtonStyle}">恢复</Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="HiddenEntriesEmptyTextBlock"
                                       Text="暂无已删除的索引。在搜索结果上右键即可删除。"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Version footer -->
                    <TextBlock x:Name="VersionTextBlock"
                               Grid.Row="7"
                               Text="QuickLauncher v1.0.3"
                               Margin="0,16,0,0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11"
                               HorizontalAlignment="Center" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
