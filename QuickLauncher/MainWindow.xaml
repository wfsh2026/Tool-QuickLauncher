<Window x:Class="QuickLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="QuickLauncher"
        Width="680"
        Height="118"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <ContextMenu x:Key="SettingsContextMenu"
                     Background="{StaticResource BgPanel}"
                     BorderBrush="{StaticResource BorderDefault}"
                     Foreground="{StaticResource TextPrimary}">
            <MenuItem Header="打开设置" Click="OpenSettingsMenuItem_OnClick" />
        </ContextMenu>
    </Window.Resources>
    <Border Margin="12"
            Padding="16"
            Background="{StaticResource BgPanel}"
            CornerRadius="{StaticResource RadiusPanel}"
            BorderBrush="{StaticResource BorderDefault}"
            BorderThickness="1"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search Bar -->
            <Border Grid.Row="0"
                    CornerRadius="{StaticResource RadiusSearch}"
                    BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="1"
                    Padding="14,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#B2111A2C" Offset="0" />
                        <GradientStop Color="#C0152034" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon (vector path) -->
                    <Border Width="32"
                            Height="32"
                            Margin="0,0,12,0"
                            CornerRadius="8"
                            Background="{StaticResource AccentSubtle}">
                        <Path Data="{StaticResource SearchIconGeometry}"
                              Fill="{StaticResource Accent}"
                              Width="18" Height="18"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>

                    <!-- Search Input + Placeholder overlay -->
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchTextBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimary}"
                                 FontSize="22"
                                 FontWeight="SemiBold"
                                 CaretBrush="{StaticResource Accent}"
                                 VerticalContentAlignment="Center"
                                 ContextMenu="{StaticResource SettingsContextMenu}"
                                 TextChanged="SearchTextBox_OnTextChanged"
                                 PreviewKeyDown="SearchTextBox_OnPreviewKeyDown" />
                        <TextBlock x:Name="PlaceholderText"
                                   Text="搜索应用、文件或命令..."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Margin="2,0,0,0" />
                    </Grid>

                    <TextBlock Grid.Column="2"
                               Margin="12,0,0,0"
                               Text="即时搜索"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Results Container -->
            <Border x:Name="ResultsContainer"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Padding="6"
                    Background="{StaticResource BgCard}"
                    CornerRadius="{StaticResource RadiusCard}"
                    BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="1"
                    Visibility="Collapsed"
                    ClipToBounds="True"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <ListBox x:Name="ResultsListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             MouseLeftButtonUp="ResultsListBox_OnMouseLeftButtonUp"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="ResultsListBox_OnSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,2" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="ContextMenu" Value="{StaticResource SettingsContextMenu}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardHover}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardSelected}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" CornerRadius="{StaticResource RadiusCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Selection indicator (left bar) -->
                                        <Border Grid.Column="0"
                                                Width="3"
                                                Margin="0,4,10,4"
                                                CornerRadius="2"
                                                VerticalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Accent}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- App Icon -->
                                        <Border Grid.Column="1"
                                                Width="40"
                                                Height="40"
                                                Margin="0,0,12,0"
                                                Background="{StaticResource AccentSubtle}"
                                                BorderBrush="{StaticResource BorderDefault}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                VerticalAlignment="Center">
                                            <Grid>
                                                <Image Source="{Binding IconImage}"
                                                       Width="22"
                                                       Height="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Stretch="Uniform" />
                                                <TextBlock Text="{Binding IconText}"
                                                           Foreground="{StaticResource Accent}"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <!-- App info -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding App.DisplayName}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SecondaryText}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>

                                        <!-- Badges -->
                                        <StackPanel Grid.Column="3"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right">
                                            <Border Margin="0,0,0,4"
                                                    Padding="8,3"
                                                    Background="{StaticResource AccentSubtle}"
                                                    BorderBrush="{StaticResource BorderFocus}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource RadiusBadge}">
                                                <TextBlock Text="{Binding MatchReason}"
                                                           Foreground="{StaticResource Accent}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                            <Border Padding="8,3"
                                                    Background="{StaticResource BgCard}"
                                                    BorderBrush="{StaticResource BorderDefault}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource RadiusBadge}">
                                                <TextBlock Text="{Binding SourceText}"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="EmptyStateTextBlock"
                               Text="暂无结果"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Keyboard hints bar -->
            <Border x:Name="HintsBar"
                    Grid.Row="2"
                    Margin="0,6,0,0"
                    Visibility="Collapsed">
                <TextBlock Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           HorizontalAlignment="Center">
                    <Run Text="↑↓" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                    <Run Text=" 导航  " />
                    <Run Text="↵" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                    <Run Text=" 启动  " />
                    <Run Text="Esc" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                    <Run Text=" 关闭  " />
                    <Run Text="Ctrl+," FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" />
                    <Run Text=" 设置" />
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
